# Discord bot
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:5000/auth/callback

# Google AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

# API
API_SECRET_KEY=
FLASK_SECRET_KEY=
FLASK_ENV=development
ALLOWED_ORIGINS=http://localhost:5173
PORT=5000

# PostgreSQL (Supabase connection string format)
# Free tier: 500MB, 2 projects, pauses after 7 days inactivity
# Get from: supabase.com > Project Settings > Database > Connection string
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-REF].supabase.co:5432/postgres

# Upstash Redis (optional but recommended for rate limiting + caching)
# Free tier: 500K commands/month, 256MB
# Get from: console.upstash.com > Redis > REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Command sync (set true only when slash commands change)
SYNC_COMMANDS=false

# Stripe (add when implementing billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
